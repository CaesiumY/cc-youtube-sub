{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YouTube Subtitle Translator",
  "version": "0.2.0",
  "identifier": "com.youtube-subtitle.translator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "YouTube Subtitle Translator",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; script-src 'self' 'unsafe-inline' https://www.youtube.com https://s.ytimg.com; style-src 'self' 'unsafe-inline'; frame-src https://www.youtube.com https://www.youtube-nocookie.com; connect-src 'self' https://www.youtube.com https://*.youtube.com https://*.ytimg.com ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/CaesiumY/cc-youtube-sub/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQyNDY3QzVGRjc3QzE5MzcKUldRM0dYejNYM3hHMGlwbTBBNVpnMUpWNE5FRjVaL3BGeXJSQjdVTlpQdXlSRld0b2luQmp2MGwK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "dmg", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "YouTube 자막을 Claude AI로 번역",
    "longDescription": "YouTube 영상의 영어 자막을 Claude AI로 실시간 번역하는 데스크톱 앱",
    "copyright": "Copyright (c) 2026 ChangSik Yoon",
    "category": "Utility",
    "license": "./LICENSE",
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["Korean", "English"]
      }
    }
  }
}
